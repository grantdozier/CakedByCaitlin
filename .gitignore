# dependencies
node_modules/
npm-debug.log*
yarn-error.log*
package-lock.json.bak

# CI staging dir for the Pages artifact.
# NOTE: index.html and sitemap.xml are generated by scripts/build.mjs but are
# deliberately NOT ignored — they are committed so the repo always reflects
# what is live.
_site/

# os / editor cruft
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*~

# env / secrets — no keys ever get committed to a public Pages repo
.env
.env.*
!.env.example
